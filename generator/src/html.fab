# HTML emitter.
#
# Turns a Pagina into a complete HTML document using the closed
# component vocabulary. The emitter cannot write CSS.
# New chrome must use document_ir.Node builders and doc_mod.html().

importa ex "./types" privata * ut types_mod
importa ex "./markdown" privata * ut markdown_mod
importa ex "./document_ir" privata * ut doc_mod

functio a(textus href, textus label) → doc_mod.Node {
    redde doc_mod.leaf("a", [doc_mod.attr("href", href)], label)
}

functio code_link(textus href, textus label) → doc_mod.Node {
    redde doc_mod.element("a", [doc_mod.attr("href", href)], [doc_mod.leaf("code", vacua, label)])
}

functio li(doc_mod.Node child) → doc_mod.Node {
    redde doc_mod.element("li", vacua, [child])
}

# Render a full HTML page from a Pagina.
functio genera_paginam(types_mod.Pagina pag, textus stylesheet_link) → textus {
    varia textus body_class ← "docs"
    si pag.section ≡ "" {
        body_class ← "home"
    }

    varia lista<doc_mod.Node> body_children ← vacua
    body_children.appende(genera_renderbar(pag.locale))

    varia lista<doc_mod.Node> page_children ← vacua
    page_children.appende(genera_sidebar(pag.section))
    page_children.appende(genera_main(pag))

    fixum doc_mod.Node footer ← genera_source_list(pag.sources)
    si non doc_mod.is_empty(footer) {
        page_children.appende(footer)
    }

    body_children.appende(doc_mod.element("div", [doc_mod.attr("class", "page")], page_children))

    fixum doc_mod.Node root ← doc_mod.element("html", [doc_mod.attr("lang", pag.locale)], [genera_head(pag, stylesheet_link), doc_mod.element("body", [doc_mod.attr("class", body_class)], body_children)])
    redde doc_mod.html(doc_mod.document(root))
}

# Generate the <head> element.
functio genera_head(types_mod.Pagina pag, textus stylesheet_link) → doc_mod.Node {
    varia textus title ← pag.titulus
    si non (pag.titulus ≡ "Faber") {
        title ← «§ — Faber»(pag.titulus)
    }

    varia lista<doc_mod.Node> children ← vacua
    children.appende(doc_mod.void_element("meta", [doc_mod.attr("charset", "utf-8")]))
    children.appende(doc_mod.void_element("meta", [doc_mod.attr("name", "viewport"), doc_mod.attr("content", "width=device-width, initial-scale=1")]))
    children.appende(doc_mod.void_element("meta", [doc_mod.attr("name", "description"), doc_mod.attr("content", "Faber programming language — package-oriented, Latin vocabulary, type-first static types. Agent-readable docs, install, and examples.")]))
    children.appende(doc_mod.void_element("meta", [doc_mod.attr("name", "theme-color"), doc_mod.attr("content", "#faf9f6"), doc_mod.attr("media", "(prefers-color-scheme: light)")]))
    children.appende(doc_mod.void_element("meta", [doc_mod.attr("name", "theme-color"), doc_mod.attr("content", "#1c1b19"), doc_mod.attr("media", "(prefers-color-scheme: dark)")]))
    children.appende(doc_mod.void_element("meta", [doc_mod.attr("property", "og:site_name"), doc_mod.attr("content", "Faber")]))
    children.appende(doc_mod.void_element("meta", [doc_mod.attr("property", "og:type"), doc_mod.attr("content", "website")]))
    children.appende(doc_mod.void_element("meta", [doc_mod.attr("property", "og:title"), doc_mod.attr("content", title)]))
    children.appende(doc_mod.void_element("meta", [doc_mod.attr("property", "og:description"), doc_mod.attr("content", "Faber programming language — package-oriented, Latin vocabulary, type-first static types.")]))
    children.appende(doc_mod.void_element("link", [doc_mod.attr("rel", "icon"), doc_mod.attr("href", "data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2064%2064'%3E%3Crect%20width='64'%20height='64'%20rx='12'%20fill='%232a4a9e'/%3E%3Ctext%20x='32'%20y='47'%20font-family='Georgia,serif'%20font-size='44'%20font-style='italic'%20text-anchor='middle'%20fill='%23faf9f6'%3Ef%3C/text%3E%3C/svg%3E")]))
    children.appende(doc_mod.void_element("link", [doc_mod.attr("rel", "alternate"), doc_mod.attr("type", "text/plain"), doc_mod.attr("href", "/llms.txt"), doc_mod.attr("title", "Agent index")]))
    children.appende(doc_mod.void_element("link", [doc_mod.attr("rel", "alternate"), doc_mod.attr("type", "text/markdown"), doc_mod.attr("href", "/agents/index.md"), doc_mod.attr("title", "Agent guide")]))
    children.appende(doc_mod.leaf("title", vacua, title))
    children.appende(doc_mod.void_element("link", [doc_mod.attr("rel", "preconnect"), doc_mod.attr("href", "https://fonts.googleapis.com")]))
    children.appende(doc_mod.void_element("link", [doc_mod.attr("rel", "preconnect"), doc_mod.attr("href", "https://fonts.gstatic.com"), doc_mod.attr("crossorigin", "")]))
    children.appende(doc_mod.void_element("link", [doc_mod.attr("href", "https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600;700&family=Noto+Serif:wght@400;600&family=Noto+Sans+Mono:wght@400;600&display=swap"), doc_mod.attr("rel", "stylesheet")]))
    children.appende(doc_mod.void_element("link", [doc_mod.attr("rel", "stylesheet"), doc_mod.attr("href", stylesheet_link)]))
    redde doc_mod.element("head", vacua, children)
}

functio genera_renderbar(textus current_locale) → doc_mod.Node {
    varia lista<doc_mod.Node> links ← vacua
    links.appende(a("/llms.txt", "/llms.txt"))
    links.appende(a("/agents/index.md", "/agents"))
    links.appende(a("/.well-known/agent-skills/index.json", "/skills"))
    links.appende(a("/start/install.html", "install"))

    fixum doc_mod.Node nav ← doc_mod.element("nav", [doc_mod.attr("class", "machine-links"), doc_mod.attr("aria-label", "Machine documentation")], links)
    fixum doc_mod.Node inner ← doc_mod.element("div", [doc_mod.attr("class", "in")], [doc_mod.leaf("span", [doc_mod.attr("class", "lbl")], "Rendering"), doc_mod.leaf("span", [doc_mod.attr("class", "locbtns")], current_locale), nav])
    redde doc_mod.element("div", [doc_mod.attr("class", "renderbar")], [inner])
}

functio genera_sidebar(textus active_section) → doc_mod.Node {
    varia lista<doc_mod.Node> children ← vacua
    children.appende(genera_brand())
    children.appende(side_h("Get started"))
    children.appende(nav_list([li(genera_nav_link("Install & download", "/start/install.html", active_section ≡ "install")), li(genera_nav_link("Hello", "/start/hello.html", active_section ≡ "hello")), li(genera_nav_link("Commands", "/start/commands.html", active_section ≡ "commands")), li(genera_nav_link("Projects", "/start/projects.html", active_section ≡ "projects")), li(genera_nav_link("Examples", "/start/examples.html", active_section ≡ "examples")), li(genera_nav_link("Quick tour", "/start/", active_section ≡ "start"))], "nav"))
    children.appende(side_h("Documentation"))

    varia lista<doc_mod.Node> docs ← vacua
    docs.appende(li(genera_nav_link("Overview", "/", active_section ≡ "")))
    docs.appende(li(genera_nav_link("Features", "/features/", active_section ≡ "features")))
    docs.appende(li(genera_nav_link("Syntax", "/syntax/", active_section ≡ "syntax")))
    docs.appende(li(genera_nav_link("Tooling", "/tooling/", active_section ≡ "tooling")))
    docs.appende(li(genera_nav_link("Ecosystem", "/ecosystem/", active_section ≡ "ecosystem")))
    docs.appende(li(genera_nav_link("Corpus", "/corpus/", active_section ≡ "corpus")))
    docs.appende(li(genera_nav_link("References", "/references/", active_section ≡ "references")))
    docs.appende(li(genera_nav_link("History", "/history/", active_section ≡ "history")))
    children.appende(nav_list(docs, "nav"))

    children.appende(side_h("For agents"))
    children.appende(nav_list([li(genera_nav_link("Agent index", "/llms.txt", falsum)), li(genera_nav_link("Agent guide", "/agents/index.md", falsum)), li(genera_nav_link("Agent skills", "/.well-known/agent-skills/index.json", falsum)), li(genera_nav_link("Full reference", "/llms-full.txt", falsum))], "nav nav-compact"))

    children.appende(side_h("Release 1.1.1"))
    children.appende(nav_list([li(genera_nav_link("macOS arm64", "https://github.com/faberlang/releases/releases/download/faber-v1.1.1/faber-v1.1.1-aarch64-apple-darwin.tar.gz", falsum)), li(genera_nav_link("Linux x64", "https://github.com/faberlang/releases/releases/download/faber-v1.1.1/faber-v1.1.1-x86_64-unknown-linux-gnu.tar.gz", falsum)), li(genera_nav_link("All releases", "https://github.com/faberlang/releases/releases/tag/faber-v1.1.1", falsum)), li(genera_nav_link("GitHub org", "https://github.com/faberlang", falsum))], "nav nav-compact"))
    children.appende(genera_side_meta())

    redde doc_mod.element("aside", vacua, children)
}

functio genera_brand() → doc_mod.Node {
    fixum doc_mod.Node mark ← doc_mod.leaf("span", [doc_mod.attr("class", "brand-mark"), doc_mod.attr("aria-hidden", "true")], "f")
    fixum doc_mod.Node name ← doc_mod.leaf("span", [doc_mod.attr("class", "brand-name")], "Faber")
    fixum doc_mod.Node tag ← doc_mod.leaf("span", [doc_mod.attr("class", "brand-tag")], "language docs")
    fixum doc_mod.Node text ← doc_mod.element("span", [doc_mod.attr("class", "brand-text")], [name, tag])
    redde doc_mod.element("a", [doc_mod.attr("class", "brand"), doc_mod.attr("href", "/")], [mark, text])
}

functio side_h(textus label) → doc_mod.Node {
    redde doc_mod.leaf("div", [doc_mod.attr("class", "side-h")], label)
}

functio nav_list(lista<doc_mod.Node> items, textus class_name) → doc_mod.Node {
    redde doc_mod.element("ul", [doc_mod.attr("class", class_name)], items)
}

functio genera_nav_link(textus label, textus href, bivalens active) → doc_mod.Node {
    si active {
        redde doc_mod.leaf("a", [doc_mod.attr("href", href), doc_mod.attr("class", "active")], label)
    }
    redde doc_mod.leaf("a", [doc_mod.attr("href", href)], label)
}

functio meta_row(textus key, textus value) → doc_mod.Node {
    redde doc_mod.element("div", [doc_mod.attr("class", "side-meta-row")], [doc_mod.leaf("span", [doc_mod.attr("class", "k")], key), doc_mod.leaf("span", [doc_mod.attr("class", "v")], value)])
}

functio genera_side_meta() → doc_mod.Node {
    redde doc_mod.element("div", [doc_mod.attr("class", "side-meta")], [meta_row("Paradigm", "packages"), meta_row("Typing", "static · type-first"), meta_row("Target", "Rust → native"), meta_row("License", "MIT")])
}

functio genera_main(types_mod.Pagina pag) → doc_mod.Node {
    fixum doc_mod.Node h1 ← doc_mod.leaf("h1", vacua, pag.titulus)
    fixum doc_mod.Node body ← genera_body(markdown_mod.converte_nodes(pag.corpus))
    si pag.section ≡ "" {
        redde doc_mod.element("main", vacua, [h1, genera_agent_notice(), body])
    }
    redde doc_mod.element("main", vacua, [h1, body])
}

functio genera_agent_notice() → doc_mod.Node {
    varia lista<doc_mod.Node> p_children ← vacua
    p_children.appende(doc_mod.text("If you are an AI agent: start at "))
    p_children.appende(code_link("/llms.txt", "/llms.txt"))
    p_children.appende(doc_mod.text(", then read "))
    p_children.appende(code_link("/agents/index.md", "/agents/index.md"))
    p_children.appende(doc_mod.text(" and pick a skill from "))
    p_children.appende(code_link("/.well-known/agent-skills/index.json", "/.well-known/agent-skills/"))
    p_children.appende(doc_mod.text(". Humans: use "))
    p_children.appende(a("/start/install.html", "Install"))
    p_children.appende(doc_mod.text(" and "))
    p_children.appende(a("/start/examples.html", "Examples"))
    p_children.appende(doc_mod.text("."))

    fixum doc_mod.Node label ← doc_mod.leaf("span", [doc_mod.attr("class", "agent-notice-label")], "Agent-ready")
    fixum doc_mod.Node paragraph ← doc_mod.element("p", vacua, p_children)
    fixum doc_mod.Node body ← doc_mod.element("div", [doc_mod.attr("class", "agent-notice-body")], [paragraph])
    redde doc_mod.element("section", [doc_mod.attr("class", "agent-notice"), doc_mod.attr("aria-label", "Agent-facing notice")], [label, body])
}

functio genera_body(lista<doc_mod.Node> markdown_nodes) → doc_mod.Node {
    redde doc_mod.element("div", [doc_mod.attr("class", "content")], markdown_nodes)
}

functio genera_source_list(lista<textus> sources) → doc_mod.Node {
    si sources.longitudo() ≡ 0 ergo redde doc_mod.text("")

    varia lista<doc_mod.Node> items ← vacua
    itera ex sources fixum src {
        items.appende(li(doc_mod.text(src)))
    }

    fixum doc_mod.Node label ← doc_mod.leaf("span", [doc_mod.attr("class", "side-h")], "Sources")
    fixum doc_mod.Node list ← doc_mod.element("ul", vacua, items)
    fixum doc_mod.Node source_list ← doc_mod.element("div", [doc_mod.attr("class", "source-list")], [label, list])
    redde doc_mod.element("footer", vacua, [source_list])
}
