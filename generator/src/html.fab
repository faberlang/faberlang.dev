# HTML emitter.
#
# Turns a Pagina into a complete HTML document using the closed
# component vocabulary. The emitter cannot write CSS.

importa ex "./types" privata * ut types_mod
importa ex "./string_util" privata * ut su
importa ex "./markdown" privata * ut markdown_mod

# Render a full HTML page from a Pagina.
functio genera_paginam(types_mod.Pagina pag, textus stylesheet_link) → textus {
    fixum textus nl_char ← su.nl()
    fixum textus head ← genera_head(pag, stylesheet_link)
    fixum textus renderbar ← genera_renderbar(pag.locale)
    fixum textus sidebar ← genera_sidebar(pag.section)
    fixum textus main_content ← genera_main(pag)
    fixum textus footer ← genera_source_list(pag.sources)

    # Body class hook: lets the stylesheet give the homepage hero
    # treatment without the generator writing any CSS.
    varia textus body_class ← "docs"
    si pag.section ≡ "" {
        body_class ← "home"
    }

    redde ((((((((((((«<!DOCTYPE html>
<html lang="§">
    »(pag.locale) + head) + nl_char) + «<body class="§">
    »(body_class)) + renderbar) + nl_char) + «<div class="page">
    ») + sidebar) + nl_char) + main_content) + nl_char) + footer) + nl_char) + «</div>
</body>
</html>»
}

# Generate the <head> element.
functio genera_head(types_mod.Pagina pag, textus stylesheet_link) → textus {
    # Avoid "Faber — Faber" when the page title is already Faber.
    varia textus title ← pag.titulus
    si non (pag.titulus ≡ "Faber") {
        title ← «§ — Faber»(pag.titulus)
    }

    redde «<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="Faber programming language — package-oriented, Latin vocabulary, type-first static types. Agent-readable docs, install, and examples.">
<meta name="theme-color" content="#faf9f6" media="(prefers-color-scheme: light)">
<meta name="theme-color" content="#1c1b19" media="(prefers-color-scheme: dark)">
<meta property="og:site_name" content="Faber">
<meta property="og:type" content="website">
<meta property="og:title" content="§0">
<meta property="og:description" content="Faber programming language — package-oriented, Latin vocabulary, type-first static types.">
<link rel="icon" href="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2064%2064'%3E%3Crect%20width='64'%20height='64'%20rx='12'%20fill='%232a4a9e'/%3E%3Ctext%20x='32'%20y='47'%20font-family='Georgia,serif'%20font-size='44'%20font-style='italic'%20text-anchor='middle'%20fill='%23faf9f6'%3Ef%3C/text%3E%3C/svg%3E">
<link rel="alternate" type="text/plain" href="/llms.txt" title="Agent index">
<link rel="alternate" type="text/markdown" href="/agents/index.md" title="Agent guide">
<title>§0</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600;700&family=Noto+Serif:wght@400;600&family=Noto+Sans+Mono:wght@400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="§1">
</head>»(title, stylesheet_link)
}

# Generate the rendering bar with machine-doc links.
functio genera_renderbar(textus current_locale) → textus {
    redde «<div class="renderbar">
  <div class="in">
    <span class="lbl">Rendering</span>
    <span class="locbtns">§</span>
    <nav class="machine-links" aria-label="Machine documentation">
      <a href="/llms.txt">/llms.txt</a>
      <a href="/agents/index.md">/agents</a>
      <a href="/.well-known/agent-skills/index.json">/skills</a>
      <a href="/start/install.html">install</a>
    </nav>
  </div>
</div>»(current_locale)
}

# Generate the sidebar navigation — denser multi-section chrome.
functio genera_sidebar(textus active_section) → textus {
    fixum textus start_install ← genera_nav_link("Install &amp; download", "/start/install.html", active_section ≡ "install")
    fixum textus start_examples ← genera_nav_link("Examples", "/start/examples.html", active_section ≡ "examples")
    fixum textus start_tour ← genera_nav_link("Quick tour", "/start/", active_section ≡ "start")

    fixum textus nav_overview ← genera_nav_link("Overview", "/", active_section ≡ "")
    fixum textus nav_features ← genera_nav_link("Features", "/features/", active_section ≡ "features")
    fixum textus nav_syntax ← genera_nav_link("Syntax", "/syntax/", active_section ≡ "syntax")
    fixum textus nav_tooling ← genera_nav_link("Tooling", "/tooling/", active_section ≡ "tooling")
    fixum textus nav_ecosystem ← genera_nav_link("Ecosystem", "/ecosystem/", active_section ≡ "ecosystem")
    fixum textus nav_corpus ← genera_nav_link("Corpus", "/corpus/", active_section ≡ "corpus")
    fixum textus nav_references ← genera_nav_link("References", "/references/", active_section ≡ "references")
    fixum textus nav_history ← genera_nav_link("History", "/history/", active_section ≡ "history")

    fixum textus agent_llms ← genera_nav_link("Agent index", "/llms.txt", falsum)
    fixum textus agent_guide ← genera_nav_link("Agent guide", "/agents/index.md", falsum)
    fixum textus agent_skills ← genera_nav_link("Agent skills", "/.well-known/agent-skills/index.json", falsum)
    fixum textus agent_full ← genera_nav_link("Full reference", "/llms-full.txt", falsum)

    fixum textus rel_darwin ← genera_nav_link("macOS arm64", "https://github.com/faberlang/releases/releases/download/faber-v1.1.1/faber-v1.1.1-aarch64-apple-darwin.tar.gz", falsum)
    fixum textus rel_linux ← genera_nav_link("Linux x64", "https://github.com/faberlang/releases/releases/download/faber-v1.1.1/faber-v1.1.1-x86_64-unknown-linux-gnu.tar.gz", falsum)
    fixum textus rel_all ← genera_nav_link("All releases", "https://github.com/faberlang/releases/releases/tag/faber-v1.1.1", falsum)
    fixum textus rel_gh ← genera_nav_link("GitHub org", "https://github.com/faberlang", falsum)

    redde «<aside>
  <a class="brand" href="/">
    <span class="brand-mark" aria-hidden="true">f</span>
    <span class="brand-text">
      <span class="brand-name">Faber</span>
      <span class="brand-tag">language docs</span>
    </span>
  </a>

  <div class="side-h">Get started</div>
  <ul class="nav">
    <li>§</li>
    <li>§</li>
    <li>§</li>
  </ul>

  <div class="side-h">Documentation</div>
  <ul class="nav">
    <li>§</li>
    <li>§</li>
    <li>§</li>
    <li>§</li>
    <li>§</li>
    <li>§</li>
    <li>§</li>
    <li>§</li>
  </ul>

  <div class="side-h">For agents</div>
  <ul class="nav nav-compact">
    <li>§</li>
    <li>§</li>
    <li>§</li>
    <li>§</li>
  </ul>

  <div class="side-h">Release 1.1.1</div>
  <ul class="nav nav-compact">
    <li>§</li>
    <li>§</li>
    <li>§</li>
    <li>§</li>
  </ul>

  <div class="side-meta">
    <div class="side-meta-row"><span class="k">Paradigm</span><span class="v">packages</span></div>
    <div class="side-meta-row"><span class="k">Typing</span><span class="v">static · type-first</span></div>
    <div class="side-meta-row"><span class="k">Target</span><span class="v">Rust → native</span></div>
    <div class="side-meta-row"><span class="k">License</span><span class="v">MIT</span></div>
  </div>
</aside>»(start_install, start_examples, start_tour, nav_overview, nav_features, nav_syntax, nav_tooling, nav_ecosystem, nav_corpus, nav_references, nav_history, agent_llms, agent_guide, agent_skills, agent_full, rel_darwin, rel_linux, rel_all, rel_gh)
}

# Generate a navigation link, marking active section.
functio genera_nav_link(textus label, textus href, bivalens active) → textus {
    si active {
        redde «<a href="§" class="active">§</a>»(href, label)
    }
    redde «<a href="§">§</a>»(href, label)
}

# Generate the main content area.
functio genera_main(types_mod.Pagina pag) → textus {
    fixum textus h1 ← "<h1>§</h1>"(pag.titulus)
    fixum textus body ← genera_body(markdown_mod.converte(pag.corpus))
    # Homepage: agent notice band above body content.
    si pag.section ≡ "" {
        fixum textus notice ← genera_agent_notice()
        redde «<main>
§
§
§
</main>»(h1, notice, body)
    }
    redde «<main>
§
§
</main>»(h1, body)
}

# Agent-first notice on the homepage (pattern: discoverability for machines).
functio genera_agent_notice() → textus {
    redde «<section class="agent-notice" aria-label="Agent-facing notice">
  <span class="agent-notice-label">Agent-ready</span>
  <div class="agent-notice-body">
    <p>If you are an AI agent: start at <a href="/llms.txt"><code>/llms.txt</code></a>,
    then read <a href="/agents/index.md"><code>/agents/index.md</code></a> and pick a skill from
    <a href="/.well-known/agent-skills/index.json"><code>/.well-known/agent-skills/</code></a>.
    Humans: use <a href="/start/install.html">Install</a> and <a href="/start/examples.html">Examples</a>.</p>
  </div>
</section>»
}

# Generate HTML from Markdown body.
functio genera_body(textus markdown) → textus {
    redde «<div class="content">
§
</div>»(markdown)
}

# Generate the source-list provenance footer.
functio genera_source_list(lista<textus> sources) → textus {
    si sources.longitudo() ≡ 0 ergo redde ""

    varia textus html ← «<footer>
<div class="source-list">
<span class="side-h">Sources</span>
<ul>
    »
    itera ex sources fixum src {
        html ← html + «  <li>§</li>
        »(src)
    }
    html ← html + «</ul>
</div>
</footer>»

    redde html
}
